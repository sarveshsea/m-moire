{
  "color": {
    "$type": "color",
    "background":         { "$value": "oklch(98% 0.02 95)" },
    "foreground":         { "$value": "oklch(18% 0.02 120)" },
    "card":               { "$value": "oklch(100% 0 0)" },
    "card-foreground":    { "$value": "oklch(18% 0.02 120)" },
    "primary":            { "$value": "oklch(52% 0.18 140)" },
    "primary-foreground": { "$value": "oklch(99% 0.01 95)" },
    "muted":              { "$value": "oklch(94% 0.03 95)" },
    "muted-foreground":   { "$value": "oklch(42% 0.03 120)" },
    "accent":             { "$value": "oklch(76% 0.16 70)" },
    "accent-foreground":  { "$value": "oklch(18% 0.02 120)" },
    "border":             { "$value": "oklch(88% 0.03 95)" },
    "input":              { "$value": "oklch(88% 0.03 95)" },
    "ring":               { "$value": "oklch(52% 0.18 140)" }
  },
  "spacing": {
    "$type": "dimension",
    "xs": { "$value": "4px" },
    "sm": { "$value": "8px" },
    "md": { "$value": "16px" },
    "lg": { "$value": "24px" },
    "xl": { "$value": "32px" }
  },
  "radius": {
    "$type": "dimension",
    "sm": { "$value": "6px" },
    "md": { "$value": "8px" },
    "lg": { "$value": "12px" }
  },
  "shadow": {
    "$type": "shadow",
    "sm": { "$value": "0 1px 2px 0 rgb(0 0 0 / 0.05)" },
    "md": { "$value": "0 4px 6px -1px rgb(0 0 0 / 0.1)" }
  }
}
