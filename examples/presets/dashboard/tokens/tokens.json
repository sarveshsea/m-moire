{
  "color": {
    "$type": "color",
    "background":         { "$value": "oklch(100% 0 0)" },
    "foreground":         { "$value": "oklch(15% 0.005 280)" },
    "card":               { "$value": "oklch(100% 0 0)" },
    "card-foreground":    { "$value": "oklch(15% 0.005 280)" },
    "primary":            { "$value": "oklch(15% 0.005 280)" },
    "primary-foreground": { "$value": "oklch(98% 0.002 280)" },
    "muted":              { "$value": "oklch(96% 0.003 280)" },
    "muted-foreground":   { "$value": "oklch(45% 0.01 280)" },
    "accent":             { "$value": "oklch(70% 0.2 250)" },
    "accent-foreground":  { "$value": "oklch(98% 0.002 280)" },
    "border":             { "$value": "oklch(90% 0.005 280)" },
    "input":              { "$value": "oklch(90% 0.005 280)" },
    "ring":               { "$value": "oklch(70% 0.2 250)" }
  },
  "color-dark": {
    "$type": "color",
    "background":         { "$value": "oklch(8% 0.005 280)" },
    "foreground":         { "$value": "oklch(98% 0.002 280)" },
    "card":               { "$value": "oklch(12% 0.006 280)" },
    "card-foreground":    { "$value": "oklch(98% 0.002 280)" },
    "primary":            { "$value": "oklch(98% 0.002 280)" },
    "primary-foreground": { "$value": "oklch(8% 0.005 280)" },
    "muted":              { "$value": "oklch(18% 0.006 280)" },
    "muted-foreground":   { "$value": "oklch(70% 0.01 280)" },
    "accent":             { "$value": "oklch(70% 0.2 250)" },
    "accent-foreground":  { "$value": "oklch(8% 0.005 280)" },
    "border":             { "$value": "oklch(22% 0.008 280)" },
    "input":              { "$value": "oklch(22% 0.008 280)" },
    "ring":               { "$value": "oklch(70% 0.2 250)" }
  },
  "spacing": {
    "$type": "dimension",
    "xs": { "$value": "4px" },
    "sm": { "$value": "8px" },
    "md": { "$value": "16px" },
    "lg": { "$value": "24px" },
    "xl": { "$value": "32px" }
  },
  "radius": {
    "$type": "dimension",
    "sm": { "$value": "4px" },
    "md": { "$value": "6px" },
    "lg": { "$value": "8px" }
  },
  "shadow": {
    "$type": "shadow",
    "sm": { "$value": "0 1px 2px 0 rgb(0 0 0 / 0.25)" },
    "md": { "$value": "0 8px 24px -4px rgb(0 0 0 / 0.35)" }
  }
}
