{
  "color": {
    "$type": "color",
    "background":         { "$value": "oklch(12% 0.03 255)" },
    "foreground":         { "$value": "oklch(97% 0.01 255)" },
    "card":               { "$value": "oklch(17% 0.03 255)" },
    "card-foreground":    { "$value": "oklch(97% 0.01 255)" },
    "primary":            { "$value": "oklch(70% 0.20 175)" },
    "primary-foreground": { "$value": "oklch(12% 0.03 255)" },
    "muted":              { "$value": "oklch(22% 0.03 255)" },
    "muted-foreground":   { "$value": "oklch(74% 0.03 255)" },
    "accent":             { "$value": "oklch(70% 0.20 175)" },
    "accent-foreground":  { "$value": "oklch(12% 0.03 255)" },
    "border":             { "$value": "oklch(30% 0.03 255)" },
    "input":              { "$value": "oklch(30% 0.03 255)" },
    "ring":               { "$value": "oklch(70% 0.20 175)" }
  },
  "spacing": {
    "$type": "dimension",
    "xs": { "$value": "4px" },
    "sm": { "$value": "8px" },
    "md": { "$value": "16px" },
    "lg": { "$value": "24px" },
    "xl": { "$value": "32px" }
  },
  "radius": {
    "$type": "dimension",
    "sm": { "$value": "6px" },
    "md": { "$value": "8px" },
    "lg": { "$value": "12px" }
  },
  "shadow": {
    "$type": "shadow",
    "sm": { "$value": "0 1px 2px 0 rgb(0 0 0 / 0.05)" },
    "md": { "$value": "0 4px 6px -1px rgb(0 0 0 / 0.1)" }
  }
}
