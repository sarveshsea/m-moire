{
  "color": {
    "$type": "color",
    "background":         { "$value": "oklch(100% 0 0)" },
    "foreground":         { "$value": "oklch(15% 0.005 250)" },
    "card":               { "$value": "oklch(100% 0 0)" },
    "card-foreground":    { "$value": "oklch(15% 0.005 250)" },
    "primary":            { "$value": "oklch(55% 0.15 250)" },
    "primary-foreground": { "$value": "oklch(98% 0.005 250)" },
    "muted":              { "$value": "oklch(96% 0.005 250)" },
    "muted-foreground":   { "$value": "oklch(45% 0.01 250)" },
    "accent":             { "$value": "oklch(55% 0.15 250)" },
    "accent-foreground":  { "$value": "oklch(98% 0.005 250)" },
    "border":             { "$value": "oklch(90% 0.005 250)" },
    "input":              { "$value": "oklch(90% 0.005 250)" },
    "ring":               { "$value": "oklch(55% 0.15 250)" }
  },
  "spacing": {
    "$type": "dimension",
    "xs": { "$value": "4px" },
    "sm": { "$value": "8px" },
    "md": { "$value": "16px" },
    "lg": { "$value": "24px" },
    "xl": { "$value": "32px" }
  },
  "radius": {
    "$type": "dimension",
    "sm": { "$value": "6px" },
    "md": { "$value": "8px" },
    "lg": { "$value": "12px" }
  },
  "shadow": {
    "$type": "shadow",
    "sm": { "$value": "0 1px 2px 0 rgb(0 0 0 / 0.05)" },
    "md": { "$value": "0 4px 6px -1px rgb(0 0 0 / 0.1)" }
  }
}
